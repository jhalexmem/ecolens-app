# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard

# Public (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Secret — server-side only, NEVER commit this value
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── EPA AirNow ──────────────────────────────────────────────────────────────
# Free registration: https://docs.airnowapi.org/
# Without this key the app still works using Open-Meteo AQI estimates,
# but official US AQI readings won't be available.
AIRNOW_API_KEY=YOUR_AIRNOW_KEY_HERE

# ─── PurpleAir (portable sensors) ─────────────────────────────────────────────
# Free developer account: https://develop.purpleair.com/ (sign in with Google)
# Generate a key on the "Keys" page — default Read + Enabled is sufficient.
# Without this key the sensor map is simply omitted from the dashboard.
PURPLEAIR_API_KEY=YOUR_PURPLEAIR_KEY_HERE

# Comma-separated list of sensor_index values for each physical sensor to show.
# Find each sensor's index in the PurpleAir app, or by searching for it at
# https://map.purpleair.com/ and reading the index from the sensor's popup/URL.
PURPLEAIR_SENSOR_INDICES=123456,234567
